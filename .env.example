# ─── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/a3cms?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Optional OAuth (uncomment to enable)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ─── Storage (choose one) ────────────────────────────────────
# UploadThing
UPLOADTHING_TOKEN=""

# AWS S3
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── Google APIs (optional, for live integrations) ───────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""
GSC_SITE_URL=""
GA4_PROPERTY_ID=""
GBP_ACCOUNT_ID=""
PAGESPEED_API_KEY=""

# ─── Misc ────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_NAME="A3 CMS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
