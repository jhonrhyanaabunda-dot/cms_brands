# deps
node_modules
.pnp
.pnp.js

# next.js
.next/
out/
build/

# misc
.DS_Store
*.pem
.vercel

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env — never commit any .env-family file (template or otherwise).
.env*.local
.env
.env.example

# prisma — keep migrations clean. Demo SQLite (prisma/dev.db) IS committed
# on purpose: it ships pre-seeded with sample data so Vercel/serverless can
# copy it to /tmp at runtime (see src/lib/db.ts). For real production, swap
# the provider to postgresql and remove the bundled file.
prisma/migrations/dev.db*
prisma/dev.db-journal

# typescript
*.tsbuildinfo
next-env.d.ts
